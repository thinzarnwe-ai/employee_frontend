# Base URL of the Employee API.
#
# DEV: leave this EMPTY. The app then uses relative URLs (/graphql, /api/...)
# which the Vite dev server proxies to the backend (see VITE_PROXY_TARGET),
# avoiding CORS entirely.
#
# PROD: set this to the backend's absolute origin, e.g. https://api.example.com
# In that case the backend must allow CORS for the `graphql` and `api/*` paths
# (publish config/cors.php and add 'graphql' to `paths`).
VITE_API_URL=

# Backend origin the Vite dev server proxies /graphql and /api to (dev only).
VITE_PROXY_TARGET=http://localhost:8000
